{
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "git-cliff": "^2.12.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "scripts": {
    "dev": "bun run --cwd ui dev",
    "build": "bun run --cwd ui build && cargo build --release",
    "format": "prettier --write ui/ --ignore-path ui/.gitignore",
    "test:e2e": "playwright test"
  },
  "workspaces": [
    "ui/"
  ]
}
