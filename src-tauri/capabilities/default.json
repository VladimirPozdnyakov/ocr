{
  "identifier": "default",
  "description": "Default capabilities for the OCR Desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-center",
    "core:window:allow-request-user-attention",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "shell:default",
    "shell:allow-open"
  ]
}
